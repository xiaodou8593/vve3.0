#$(module_prefix)test/cp/start

function vve:_init
function $(module_prefix)init

kill @e[tag=test]

# 生成测试程序实体
data modify storage $(project_name):io input set from storage $(project_name):class $(module_name)_plate
function $(module_prefix)_proj
execute positioned 0.0 0.0 0.0 rotated 0.0 0.0 as @e[tag=math_marker,limit=1] run function vve:object/_anchor_to
function $(module_prefix)_model
data modify storage $(project_name):io input set from storage $(project_name):io result
function $(module_prefix)_new
tag @e[tag=result,limit=1] add test
tag @e[tag=result,limit=1] remove $(module_name)

execute as @e[tag=result,limit=1] run function marker_control:data/_get

# 设置测试程序主函数和销毁函数
data modify storage marker_control:io result.tick_func set value "$(module_prefix)test/cp/main"
data modify storage marker_control:io result.del_func set value "$(module_prefix)test/cp/end"

execute as @e[tag=result,limit=1] run function marker_control:data/_store
tag @e[tag=result,limit=1] add entity_ticked
tag @e[tag=result,limit=1] add entity_todel

# 设置测试程序运行时间
scoreboard players set @e[tag=result,limit=1] killtime 10
scoreboard players set test int -1

# 设置旋转
execute at @e[tag=result,limit=1] positioned ~5.0 ~5.0 ~5.0 run function $(module_prefix)test/cp/rotate_here